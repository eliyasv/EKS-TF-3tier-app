pipeline {
    agent any
    tools {
        nodejs 'nodejs'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_ACCOUNT_ID = credentials('ACCOUNT_ID')
        AWS_ECR_REPO_NAME = 'frontend'
        AWS_DEFAULT_REGION = 'us-east-1'
        ECR_REPO_URL = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        GIT_REPO_NAME = 'EKS-TF-3tier-app'
        GIT_USER_NAME = 'eliyasv'
    }
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'main', credentialsId: 'GITHUB', url: 'https://github.com/eliyasv/EKS-TF-3tier-app.git'
            }
        }
        stage('Build Metadata') {
            steps {
                script {
                    env.GIT_COMMIT_SHORT = env.GIT_COMMIT?.take(7) ?: sh(script: 'git rev-parse --short HEAD', returnStdout: true).trim()
                    env.IMAGE_TAG = "${BUILD_NUMBER}-${GIT_COMMIT_SHORT}"
                    echo "Image tag: ${IMAGE_TAG}"
                }
            }
        }
        stage('Validate Frontend Package') {
            steps {
                dir('App-Code/frontend') {
                    sh 'npm ci'
                    sh 'npm run build'
                }
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('App-Code/frontend') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''$SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=frontend \
                        -Dsonar.projectKey=frontend'''
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {
                        def qg = waitForQualityGate abortPipeline: true
                        if (qg.status != 'OK') {
                            error "SonarQube Quality Gate failed: ${qg.status}"
                        }
                    }
                }
            }
        }
        stage('OWASP Dependency Check') {
            steps {
                dir('App-Code/frontend') {
                    dependencyCheck additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit', odcInstallation: 'DP-Check'
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }
        stage('Trivy File Scan') {
            steps {
                dir('App-Code/frontend') {
                    sh 'trivy fs . -f table -o trivyfs-frontend.txt'
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                script {
                    dir('App-Code/frontend') {
                        sh "docker build --pull -t ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${IMAGE_TAG} ."
                    }
                }
            }
        }
        stage('Push to ECR') {
            steps {
                script {
                    sh 'aws ecr get-login-password --region $AWS_DEFAULT_REGION | docker login --username AWS --password-stdin $ECR_REPO_URL'
                    sh "docker push ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${IMAGE_TAG}"
                }
            }
        }
        stage('Trivy Image Scan') {
            steps {
                sh "trivy image ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${IMAGE_TAG} -f table -o trivyimage-frontend.txt"
            }
        }
    }
    post {
        always {
            cleanWs()
            archiveArtifacts artifacts: '**/trivy*.txt', allowEmptyArchive: true
            archiveArtifacts artifacts: '**/dependency-check-report.xml', allowEmptyArchive: true
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs.'
        }
    }
}
