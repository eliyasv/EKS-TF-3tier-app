pipeline {
    agent any
    tools {
        nodejs 'nodejs'
    }
    environment {
        SCANNER_HOME = tool 'sonar-scanner'
        AWS_ACCOUNT_ID = credentials('ACCOUNT_ID')
        AWS_ECR_REPO_NAME = 'backend'
        AWS_DEFAULT_REGION = 'us-east-1'
        ECR_REPO_URL = "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_DEFAULT_REGION}.amazonaws.com"
        GIT_REPO_NAME = 'EKS-TF-3tier-app'
        GIT_USER_NAME = 'eliyasv'
    }
    stages {
        stage('Cleaning Workspace') {
            steps {
                cleanWs()
            }
        }
        stage('Checkout') {
            steps {
                git branch: 'main', credentialsId: 'GITHUB', url: 'https://github.com/eliyasv/EKS-TF-3tier-app.git'
            }
        }
        stage('SonarQube Analysis') {
            steps {
                dir('App-Code/backend') {
                    withSonarQubeEnv('sonar-server') {
                        sh '''$SCANNER_HOME/bin/sonar-scanner \
                        -Dsonar.projectName=backend \
                        -Dsonar.projectKey=backend'''
                    }
                }
            }
        }
        stage('Quality Gate') {
            steps {
                script {
                    timeout(time: 10, unit: 'MINUTES') {
                        def qg = waitForQualityGate abortPipeline: false
                        if (qg.status != 'OK') {
                            echo "SonarQube Quality Gate failed: ${qg.status}"
                        }
                    }
                }
            }
        }
        stage('OWASP Dependency Check') {
            steps {
                dir('App-Code/backend') {
                    dependencyCheck additionalArguments: '--scan ./ --disableYarnAudit --disableNodeAudit', odcInstallation: 'DP-Check'
                    dependencyCheckPublisher pattern: '**/dependency-check-report.xml'
                }
            }
        }
        stage('Trivy File Scan') {
            steps {
                dir('App-Code/backend') {
                    sh 'trivy fs . -f table -o trivyfs-backend.txt'
                }
            }
        }
        stage('Build Docker Image') {
            steps {
                script {
                    dir('App-Code/backend') {
                        sh 'docker system prune -f'
                        sh 'docker container prune -f'
                        sh "docker build -t ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} ."
                    }
                }
            }
        }
        stage('Push to ECR') {
            steps {
                script {
                    sh 'aws ecr get-login-password --region $AWS_DEFAULT_REGION | docker login --username AWS --password-stdin $ECR_REPO_URL'
                    sh "docker tag ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}"
                    sh "docker push ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}"
                }
            }
        }
        stage('Trivy Image Scan') {
            steps {
                sh "trivy image ${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER} -f table -o trivyimage-backend.txt"
            }
        }
        stage('Update Deployment file') {
            steps {
                dir('k8s/backend') {
                    withCredentials([string(credentialsId: 'github', variable: 'GITHUB_TOKEN')]) {
                        sh '''
                            git config user.email "eliyasvarghese97@gmail.com"
                            git config user.name "eliyasv"
                            CURRENT_IMAGE=$(grep -oP "(?<=image: ).*" deployment.yaml)
                            NEW_IMAGE="${ECR_REPO_URL}/${AWS_ECR_REPO_NAME}:${BUILD_NUMBER}"
                            echo "Updating from: $CURRENT_IMAGE"
                            echo "Updating to: $NEW_IMAGE"
                            sed -i "s|image: .*|image: ${NEW_IMAGE}|" deployment.yaml
                            git add deployment.yaml
                            git diff --cached --quiet || {
                                git commit -m "Update backend deployment image to version ${BUILD_NUMBER}"
                                git push https://${GITHUB_TOKEN}@github.com/${GIT_USER_NAME}/${GIT_REPO_NAME} HEAD:main
                            }
                        '''
                    }
                }
            }
        }
    }
    post {
        always {
            cleanWs()
            sh 'docker system prune -f'
            sh 'docker container prune -f'
            archiveArtifacts artifacts: '**/trivy*.txt', allowEmptyArchive: true
            archiveArtifacts artifacts: '**/dependency-check-report.xml', allowEmptyArchive: true
        }
        success {
            echo 'Pipeline completed successfully!'
        }
        failure {
            echo 'Pipeline failed. Please check the logs.'
        }
    }
}
